<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="spider">

  <!-- ============================================================
       SPIDER QUADRUPED ROBOT - URDF/XACRO
       Hito 1: Structural model for Ignition Gazebo 6 / ROS2 Humble
       4 legs in X-pattern: front_right(45°), front_left(135°),
                             back_left(-135°), back_right(-45°)
       3 DOF per leg: coxa(Z), femur(Y), tibia(Y)
  ============================================================ -->

  <!-- ============================================================
       INERTIA MACROS (analytic formulas for primitives)
  ============================================================ -->

  <!-- Solid sphere: Ixx=Iyy=Izz = 2/5 * m * r^2 -->
  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${2.0/5.0 * m * r * r}"
        iyy="${2.0/5.0 * m * r * r}"
        izz="${2.0/5.0 * m * r * r}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- Solid cylinder (axis Z): Ixx=Iyy = m*(3r^2+l^2)/12  Izz = m*r^2/2 -->
  <xacro:macro name="cylinder_inertia" params="m r l">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${m * (3*r*r + l*l) / 12.0}"
        iyy="${m * (3*r*r + l*l) / 12.0}"
        izz="${m * r * r / 2.0}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- ============================================================
       LEG MACRO
       Parameters:
         leg_name  - identifier (front_right, front_left, back_left, back_right)
         hip_x     - X position of coxa joint on base sphere surface
         hip_y     - Y position of coxa joint on base sphere surface
         hip_z     - Z position of coxa joint (0 = equator of sphere)
         hip_yaw   - Initial rotation of the coxa around Z (for visual alignment)
  ============================================================ -->
  <xacro:macro name="leg" params="leg_name hip_x hip_y hip_z hip_yaw">

    <!-- COXA LINK -->
    <!-- Cylinder r=0.02 l=0.06, mass=0.08 kg, axis along Z of joint -->
    <link name="${leg_name}_coxa_link">
      <xacro:cylinder_inertia m="0.08" r="0.02" l="0.06"/>
      <visual>
        <origin xyz="0 0 0.03" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.02" length="0.06"/>
        </geometry>
        <material name="dark_gray">
          <color rgba="0.3 0.3 0.3 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0.03" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.02" length="0.06"/>
        </geometry>
      </collision>
    </link>

    <!-- COXA JOINT: revolute around Z, mounted on base sphere surface -->
    <joint name="${leg_name}_coxa_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${leg_name}_coxa_link"/>
      <origin xyz="${hip_x} ${hip_y} ${hip_z}" rpy="0 0 ${hip_yaw}"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-pi/2}" upper="${pi/2}" effort="10.0" velocity="3.14"/>
      <dynamics damping="0.1" friction="0.0"/>
    </joint>

    <!-- FEMUR LINK -->
    <!-- Cylinder r=0.018 l=0.12, mass=0.15 kg -->
    <!-- Oriented along X when joint=0, so cylinder axis is along X (rpy="0 pi/2 0") -->
    <link name="${leg_name}_femur_link">
      <xacro:cylinder_inertia m="0.15" r="0.018" l="0.12"/>
      <visual>
        <origin xyz="0.06 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="0.018" length="0.12"/>
        </geometry>
        <material name="gray">
          <color rgba="0.5 0.5 0.5 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0.06 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="0.018" length="0.12"/>
        </geometry>
      </collision>
    </link>

    <!-- FEMUR JOINT: revolute around Y -->
    <joint name="${leg_name}_femur_joint" type="revolute">
      <parent link="${leg_name}_coxa_link"/>
      <child link="${leg_name}_femur_link"/>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${-pi/3}" upper="${pi/3}" effort="10.0" velocity="3.14"/>
      <dynamics damping="0.1" friction="0.0"/>
    </joint>

    <!-- TIBIA LINK -->
    <!-- Cylinder r=0.015 l=0.15, mass=0.10 kg -->
    <link name="${leg_name}_tibia_link">
      <xacro:cylinder_inertia m="0.10" r="0.015" l="0.15"/>
      <visual>
        <origin xyz="0.075 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="0.015" length="0.15"/>
        </geometry>
        <material name="light_gray">
          <color rgba="0.7 0.7 0.7 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0.075 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="0.015" length="0.15"/>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <!-- TIBIA JOINT: revolute around Y -->
    <joint name="${leg_name}_tibia_joint" type="revolute">
      <parent link="${leg_name}_femur_link"/>
      <child link="${leg_name}_tibia_link"/>
      <origin xyz="0.12 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${-2*pi/3}" upper="0" effort="10.0" velocity="3.14"/>
      <dynamics damping="0.1" friction="0.0"/>
    </joint>

    <!-- TRANSMISSION: coxa -->
    <transmission name="${leg_name}_coxa_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${leg_name}_coxa_joint">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="${leg_name}_coxa_joint_motor">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>

    <!-- TRANSMISSION: femur -->
    <transmission name="${leg_name}_femur_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${leg_name}_femur_joint">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="${leg_name}_femur_joint_motor">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>

    <!-- TRANSMISSION: tibia -->
    <transmission name="${leg_name}_tibia_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${leg_name}_tibia_joint">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="${leg_name}_tibia_joint_motor">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>

  </xacro:macro>

  <!-- ============================================================
       BASE_FOOTPRINT (virtual ground-plane reference frame)
  ============================================================ -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.18" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       BASE_LINK: central sphere
       r=0.12 m, mass=1.5 kg
       Inertia (solid sphere): I = 2/5 * 1.5 * 0.12^2 = 0.00864 kg·m²
  ============================================================ -->
  <link name="base_link">
    <xacro:sphere_inertia m="1.5" r="0.12"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
      <material name="orange">
        <color rgba="0.9 0.4 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================
       LEG INSTANTIATION
       Hip positions on the sphere surface (r=0.12):
         front_right  ( 45°): x= 0.08485, y= 0.08485
         front_left   (135°): x=-0.08485, y= 0.08485
         back_left   (-135°): x=-0.08485, y=-0.08485
         back_right   (-45°): x= 0.08485, y=-0.08485
  ============================================================ -->

  <!-- front_right: hip_yaw = pi/4 = 0.7854 rad -->
  <xacro:leg leg_name="front_right"
             hip_x="0.08485" hip_y="0.08485" hip_z="0.0"
             hip_yaw="${pi/4}"/>

  <!-- front_left: hip_yaw = 3*pi/4 = 2.3562 rad -->
  <xacro:leg leg_name="front_left"
             hip_x="-0.08485" hip_y="0.08485" hip_z="0.0"
             hip_yaw="${3*pi/4}"/>

  <!-- back_left: hip_yaw = -3*pi/4 = -2.3562 rad -->
  <xacro:leg leg_name="back_left"
             hip_x="-0.08485" hip_y="-0.08485" hip_z="0.0"
             hip_yaw="${-3*pi/4}"/>

  <!-- back_right: hip_yaw = -pi/4 = -0.7854 rad -->
  <xacro:leg leg_name="back_right"
             hip_x="0.08485" hip_y="-0.08485" hip_z="0.0"
             hip_yaw="${-pi/4}"/>

  <!-- ============================================================
       ROS2_CONTROL HARDWARE INTERFACE
  ============================================================ -->
  <ros2_control name="spider_ign_ros2_control" type="system">
    <hardware>
      <plugin>ign_ros2_control/IgnitionSystem</plugin>
    </hardware>

    <!-- front_right -->
    <joint name="front_right_coxa_joint">
      <command_interface name="position">
        <param name="min">${-pi/2}</param>
        <param name="max">${pi/2}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_right_femur_joint">
      <command_interface name="position">
        <param name="min">${-pi/3}</param>
        <param name="max">${pi/3}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_right_tibia_joint">
      <command_interface name="position">
        <param name="min">${-2*pi/3}</param>
        <param name="max">0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- front_left -->
    <joint name="front_left_coxa_joint">
      <command_interface name="position">
        <param name="min">${-pi/2}</param>
        <param name="max">${pi/2}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_left_femur_joint">
      <command_interface name="position">
        <param name="min">${-pi/3}</param>
        <param name="max">${pi/3}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_left_tibia_joint">
      <command_interface name="position">
        <param name="min">${-2*pi/3}</param>
        <param name="max">0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- back_left -->
    <joint name="back_left_coxa_joint">
      <command_interface name="position">
        <param name="min">${-pi/2}</param>
        <param name="max">${pi/2}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="back_left_femur_joint">
      <command_interface name="position">
        <param name="min">${-pi/3}</param>
        <param name="max">${pi/3}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="back_left_tibia_joint">
      <command_interface name="position">
        <param name="min">${-2*pi/3}</param>
        <param name="max">0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- back_right -->
    <joint name="back_right_coxa_joint">
      <command_interface name="position">
        <param name="min">${-pi/2}</param>
        <param name="max">${pi/2}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="back_right_femur_joint">
      <command_interface name="position">
        <param name="min">${-pi/3}</param>
        <param name="max">${pi/3}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="back_right_tibia_joint">
      <command_interface name="position">
        <param name="min">${-2*pi/3}</param>
        <param name="max">0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ============================================================
       GAZEBO PLUGIN: ign_ros2_control
  ============================================================ -->
  <gazebo>
    <plugin filename="ign_ros2_control-system"
            name="ign_ros2_control::IgnitionROS2ControlPlugin">
      <parameters>$(find spider_description)/config/controllers.yaml</parameters>
      <ros>
        <remapping>/controller_manager/robot_description:=/robot_description</remapping>
      </ros>
    </plugin>
  </gazebo>

</robot>
